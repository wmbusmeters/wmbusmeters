driver {
    name           = waterstarm
    meter_type     = WaterMeter
    default_fields = name,id,total_m3,total_backwards_m3,status,timestamp
    detect {
        mvt = DWZ,00,06
        mvt = DWZ,02,06
        mvt = DWZ,02,07
        mvt = EFE,03,07
        mvt = EFE,70,07
        mvt = DWZ,00,07
    }
    library {
        use = total_m3
        use = battery_v
    }
    fields {
        field {
            name       = status
            quantity   = Text
            info       = 'Status and error flags.'
            attributes = STATUS,INCLUDE_TPL_STATUS
            match {
                measurement_type = Instantaneous
                vif_range        = ErrorFlags
            }
            lookup {
                name            = ERROR_FLAGS
                map_type        = BitToString
                mask_bits       = 0xffff
                default_message = OK
                map {
                    name  = SW_ERROR
                    value = 0x01
                    test  = Set
                }
                map {
                    name  = CRC_ERROR
                    value = 0x02
                    test  = Set
                }
                map {
                    name  = SENSOR_ERROR
                    value = 0x04
                    test  = Set
                }
                map {
                    name  = MEASUREMENT_ERROR
                    value = 0x08
                    test  = Set
                }
                map {
                    name  = BATTERY_VOLTAGE_ERROR
                    value = 0x10
                    test  = Set
                }
                map {
                    name  = MANIPULATION
                    value = 0x20
                    test  = Set
                }
                map {
                    name  = LEAKAGE_OR_NO_USAGE
                    value = 0x40
                    test  = Set
                }
                map {
                    name  = REVERSE_FLOW
                    value = 0x80
                    test  = Set
                }
                map {
                    name  = OVERLOAD
                    value = 0x100
                    test  = Set
                }
            }
        }
        field {
            name     = total_backwards
            quantity = Volume
            info     = 'The total backward water volume recorded by this meter.'
            match {
                measurement_type = Instantaneous
                vif_range        = AnyVolumeVIF
                add_combinable   = BackwardFlow
            }
        }
        field {
            name     = meter_version
            quantity = Text
            info     = 'Meter model/version.'
            match {
                measurement_type = Instantaneous
                vif_range        = ModelVersion
            }
        }
        field {
            name     = parameter_set
            quantity = Text
            info     = 'Parameter set.'
            match {
                measurement_type = Instantaneous
                vif_range        = ParameterSet
            }
        }
        field {
            name         = set
            quantity     = PointInTime
            info         = 'The most recent billing period date.'
            display_unit = DateLT
            match {
                measurement_type = Instantaneous
                vif_range        = Date
                storage_nr       = 1
            }
        }
        field {
            name     = consumption_at_set_date
            quantity = Volume
            info     = 'The total water consumption at the most recent billing period date.'
            match {
                measurement_type = Instantaneous
                vif_range        = Volume
                storage_nr       = 1
            }
        }
        field {
            name     = total_backwards_at_set_date
            quantity = Volume
            info     = 'The total backward water volume recorded by this meter at the most recent billing period date.'
            match {
                measurement_type = Instantaneous
                vif_range        = AnyVolumeVIF
                storage_nr       = 1
                add_combinable   = BackwardFlow
            }
        }
        field {
            name     = 'consumption_at_history_{storage_counter - 1 counter}'
            quantity = Volume
            info     = 'The total backward water volume recorded by this meter at the most recent billing period date.'
            match {
                measurement_type = Instantaneous
                vif_range        = Volume
                storage_nr       = 2,16
            }
        }
        field {
            name     = meter
            quantity = PointInTime
            info     = 'Meter datetime.'
            match {
                measurement_type = Instantaneous
                vif_range        = DateTime
            }
        }
        // These history_7_date values should probably be removed.
        field {
            name         = 'history_{storage_counter - 1 counter}'
            quantity     = PointInTime
            info         = 'The historic date.'
            display_unit = DateLT
            calculate    = 'meter_datetime - ((storage_counter-1counter) * 1 month)'
            match {
                measurement_type = Instantaneous
                vif_range        = Volume
                storage_nr       = 2,16
            }
        }
    }
    tests {
        test {
            args     = 'Woter waterstarm 20096221 BEDB81B52C29B5C143388CBB0D15A051'
            telegram = 3944FA122162092002067A3600202567C94D48D00DC47B11213E23383DB51968A705AAFA60C60E263D50CD259D7C9A03FD0C08000002FD0B0011
            json     = '{"_":"telegram","media":"warm water","meter":"waterstarm","name":"Woter","id":"20096221","meter_datetime":"2020-07-30 10:40","total_m3":0.106,"total_backwards_m3":0,"status":"OK","meter_version":"000008","parameter_set":"1100","timestamp":"1111-11-11T11:11:11Z"}'
            fields   = 'Woter;20096221;0.106;0;OK;1111-11-11 11:11.11'
        }
        test {
            args     = 'Woter waterstarm 20096221 BEDB81B52C29B5C143388CBB0D15A051'
            telegram = 3944FA122162092002067A3604202567C94D48D00DC47B11213E23383DB51968A705AAFA60C60E263D50CD259D7C9A03FD0C08000002FD0B0011
            json     = '{"_":"telegram","media":"warm water","meter":"waterstarm","name":"Woter","id":"20096221","meter_datetime":"2020-07-30 10:40","total_m3":0.106,"total_backwards_m3":0,"status":"POWER_LOW","meter_version":"000008","parameter_set":"1100","timestamp":"1111-11-11T11:11:11Z"}'
            fields   = 'Woter;20096221;0.106;0;POWER_LOW;1111-11-11 11:11.11'
        }
        test {
            args     = 'Water waterstarm 22996221 NOKEY'
            telegram = 3944FA122162992202067A360420252F2F_046D282A9E2704136A00000002FD17400004933C000000002F2F2F2F2F2F03FD0C08000002FD0B0011
            json     = '{"_":"telegram","media":"warm water","meter":"waterstarm","name":"Water","id":"22996221","meter_datetime":"2020-07-30 10:40","total_m3":0.106,"total_backwards_m3":0,"status":"LEAKAGE_OR_NO_USAGE POWER_LOW","meter_version":"000008","parameter_set":"1100","timestamp":"1111-11-11T11:11:11Z"}'
            fields   = 'Water;22996221;0.106;0;LEAKAGE_OR_NO_USAGE POWER_LOW;1111-11-11 11:11.11'
        }
        test {
            args     = 'Water waterstarm 11559999 NOKEY'
            telegram = 2E44FA129999551100077A070020252F2F_046D0F28C22404139540000002FD17000001FD481D2F2F2F2F2F2F2F2F2F
            json     = '{"_":"telegram","media":"water","meter":"waterstarm","name":"Water","id":"11559999","meter_datetime":"2022-04-02 08:15","total_m3":16.533,"status":"OK","battery_v":2.9,"timestamp":"1111-11-11T11:11:11Z"}'
