driver {
    name           = axis
    meter_type     = HeatMeter
    default_fields = name,id,status,total_energy_kwh,target_energy_kwh,timestamp
    detect {
        mvt = AXI,07,04
    }
    library {
        use = fabrication_no
        use = operating_time_h
        use = on_time_h
        use = meter_datetime
        use = total_m3
        use = flow_temperature_c
        use = return_temperature_c
        use = flow_return_temperature_difference_c
        use = volume_flow_m3h
    }
    fields {
        field {
            name       = status
            quantity   = Text
            info       = 'Meter status. Includes both meter error field and tpl status field.'
            attributes = STATUS,INCLUDE_TPL_STATUS
            match {
                measurement_type = Instantaneous
                vif_range        = ErrorFlags
            }
            lookup {
                name            = ERROR_FLAGS
                map_type        = BitToString
                mask_bits       = 0xffffffff
                default_message = OK
            }
        }
        field {
            name           = total_energy
            quantity       = Energy
            info           = 'The total heat energy consumption recorded by this meter.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = AnyEnergyVIF
            }
        }
        field {
            name           = power
            quantity       = Power
            info           = 'The current power consumption.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = AnyPowerVIF
            }
        }
        field {
            name         = target
            quantity     = PointInTime
            info         = 'Date and time when the previous billing period ended.'
            display_unit = datetime
            match {
                measurement_type = Instantaneous
                vif_range        = DateTime
                storage_nr       = 1
            }
        }
        field {
            name         = target
            quantity     = PointInTime
            info         = 'Date when the previous billing period ended.'
            display_unit = date
            match {
                measurement_type = Instantaneous
                vif_range        = Date
                storage_nr       = 1
            }
        }
        field {
            name           = target_energy
            quantity       = Energy
            info           = 'The heat energy consumption at the end of the previous billing period.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = AnyEnergyVIF
                storage_nr       = 1
            }
        }
        field {
            name     = target_volume
            quantity = Volume
            info     = 'The total volume of heating media at the end of the previous billing period.'
            match {
                measurement_type = Instantaneous
                vif_range        = Volume
                storage_nr       = 1
            }
        }
    }
    tests {
        test {
            args     = 'AxisHeat axis 11223344 NOKEY'
            comment  = 'Synthetic telegram constructed from OMS standard field layout for Axioma Qalcosonic W1/E3 heat meter.'
            telegram = 634409074433221107047A00000000046D030FB72604FD170000000004200F13CF0104240F13CF010406F4010000041310270000042B88130000043B6400000002596419025D94110261D0070C7844332211446D0000A1214406900100004413401F0000
            json     = '{"_":"telegram","fabrication_no":"11223344","flow_return_temperature_difference_c":20,"flow_temperature_c":65,"id":"11223344","media":"heat","meter":"axis","meter_datetime":"2021-06-23 15:03","name":"AxisHeat","on_time_h":8430.013056,"operating_time_h":8430.013056,"power_kw":5,"return_temperature_c":45,"status":"OK","target_datetime":"2021-01-01 00:00","target_energy_kwh":400,"target_volume_m3":8,"timestamp":"1111-11-11T11:11:11Z","total_energy_kwh":500,"total_m3":10,"volume_flow_m3h":0.1}'
            fields   = 'AxisHeat;11223344;OK;500;400;1111-11-11 11:11.11'
        }
    }
}
