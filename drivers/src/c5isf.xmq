driver {
    name           = c5isf
    meter_type     = HeatMeter
    default_fields = name,id,total_energy_consumption_kwh,total_volume_m3,status,timestamp
    detect {
        mvt = ZRI,88,0d
        mvt = ZRI,88,07
        mvt = ZRI,88,04
    }
    fields {
        field {
            name     = prev_1_month
            quantity = Text
            info     = 'The due date.'
            match {
                measurement_type = Instantaneous
                vif_range        = Date
                storage_nr       = 32
            }
        }
        field {
            name     = prev_2_month
            quantity = Text
            info     = 'The due date.'
            match {
                measurement_type = Instantaneous
                vif_range        = Date
                storage_nr       = 33
            }
        }
        field {
            name     = prev_3_month
            quantity = Text
            info     = 'The due date.'
            match {
                measurement_type = Instantaneous
                vif_range        = Date
                storage_nr       = 34
            }
        }
        field {
            name     = prev_4_month
            quantity = Text
            info     = 'The due date.'
            match {
                measurement_type = Instantaneous
                vif_range        = Date
                storage_nr       = 35
            }
        }
        field {
            name     = prev_5_month
            quantity = Text
            info     = 'The due date.'
            match {
                measurement_type = Instantaneous
                vif_range        = Date
                storage_nr       = 36
            }
        }
        field {
            name     = prev_6_month
            quantity = Text
            info     = 'The due date.'
            match {
                measurement_type = Instantaneous
                vif_range        = Date
                storage_nr       = 37
            }
        }
        field {
            name     = prev_7_month
            quantity = Text
            info     = 'The due date.'
            match {
                measurement_type = Instantaneous
                vif_range        = Date
                storage_nr       = 38
            }
        }
        field {
            name     = prev_8_month
            quantity = Text
            info     = 'The due date.'
            match {
                measurement_type = Instantaneous
                vif_range        = Date
                storage_nr       = 39
            }
        }
        field {
            name     = prev_9_month
            quantity = Text
            info     = 'The due date.'
            match {
                measurement_type = Instantaneous
                vif_range        = Date
                storage_nr       = 40
            }
        }
        field {
            name     = prev_10_month
            quantity = Text
            info     = 'The due date.'
            match {
                measurement_type = Instantaneous
                vif_range        = Date
                storage_nr       = 41
            }
        }
        field {
            name     = prev_11_month
            quantity = Text
            info     = 'The due date.'
            match {
                measurement_type = Instantaneous
                vif_range        = Date
                storage_nr       = 42
            }
        }
        field {
            name     = prev_12_month
            quantity = Text
            info     = 'The due date.'
            match {
                measurement_type = Instantaneous
                vif_range        = Date
                storage_nr       = 43
            }
        }
        field {
            name     = prev_13_month
            quantity = Text
            info     = 'The due date.'
            match {
                measurement_type = Instantaneous
                vif_range        = Date
                storage_nr       = 44
            }
        }
        field {
            name     = prev_14_month
            quantity = Text
            info     = 'The due date.'
            match {
                measurement_type = Instantaneous
                vif_range        = Date
                storage_nr       = 45
            }
        }
        field {
            name           = prev_1_month
            quantity       = Energy
            info           = 'The total heat energy consumption recorded at end of previous month.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = AnyEnergyVIF
                storage_nr       = 32
            }
        }
        field {
            name           = prev_2_month
            quantity       = Energy
            info           = 'The total heat energy consumption recorded at end of previous month.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = AnyEnergyVIF
                storage_nr       = 33
            }
        }
        field {
            name           = prev_3_month
            quantity       = Energy
            info           = 'The total heat energy consumption recorded at end of previous month.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = AnyEnergyVIF
                storage_nr       = 34
            }
        }
        field {
            name           = prev_4_month
            quantity       = Energy
            info           = 'The total heat energy consumption recorded at end of previous month.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = AnyEnergyVIF
                storage_nr       = 35
            }
        }
        field {
            name           = prev_5_month
            quantity       = Energy
            info           = 'The total heat energy consumption recorded at end of previous month.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = AnyEnergyVIF
                storage_nr       = 36
            }
        }
        field {
            name           = prev_6_month
            quantity       = Energy
            info           = 'The total heat energy consumption recorded at end of previous month.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = AnyEnergyVIF
                storage_nr       = 37
            }
        }
        field {
            name           = prev_7_month
            quantity       = Energy
            info           = 'The total heat energy consumption recorded at end of previous month.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = AnyEnergyVIF
                storage_nr       = 38
            }
        }
        field {
            name           = prev_8_month
            quantity       = Energy
            info           = 'The total heat energy consumption recorded at end of previous month.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = AnyEnergyVIF
                storage_nr       = 39
            }
        }
        field {
            name           = prev_9_month
            quantity       = Energy
            info           = 'The total heat energy consumption recorded at end of previous month.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = AnyEnergyVIF
                storage_nr       = 40
            }
        }
        field {
            name           = prev_10_month
            quantity       = Energy
            info           = 'The total heat energy consumption recorded at end of previous month.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = AnyEnergyVIF
                storage_nr       = 41
            }
        }
        field {
            name           = prev_11_month
            quantity       = Energy
            info           = 'The total heat energy consumption recorded at end of previous month.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = AnyEnergyVIF
                storage_nr       = 42
            }
        }
        field {
            name           = prev_12_month
            quantity       = Energy
            info           = 'The total heat energy consumption recorded at end of previous month.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = AnyEnergyVIF
                storage_nr       = 43
            }
        }
        field {
            name           = prev_13_month
            quantity       = Energy
            info           = 'The total heat energy consumption recorded at end of previous month.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = AnyEnergyVIF
                storage_nr       = 44
            }
        }
        field {
            name           = prev_14_month
            quantity       = Energy
            info           = 'The total heat energy consumption recorded at end of previous month.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = AnyEnergyVIF
                storage_nr       = 45
            }
        }
        field {
            name           = prev_1_month
            quantity       = Volume
            info           = 'Previous month %d last date.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = Volume
                storage_nr       = 32
            }
        }
        field {
            name           = prev_2_month
            quantity       = Volume
            info           = 'Previous month %d last date.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = Volume
                storage_nr       = 33
            }
        }
        field {
            name           = prev_3_month
            quantity       = Volume
            info           = 'Previous month %d last date.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = Volume
                storage_nr       = 34
            }
        }
        field {
            name           = prev_4_month
            quantity       = Volume
            info           = 'Previous month %d last date.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = Volume
                storage_nr       = 35
            }
        }
        field {
            name           = prev_5_month
            quantity       = Volume
            info           = 'Previous month %d last date.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = Volume
                storage_nr       = 36
            }
        }
        field {
            name           = prev_6_month
            quantity       = Volume
            info           = 'Previous month %d last date.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = Volume
                storage_nr       = 37
            }
        }
        field {
            name           = prev_7_month
            quantity       = Volume
            info           = 'Previous month %d last date.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = Volume
                storage_nr       = 38
            }
        }
        field {
            name           = prev_8_month
            quantity       = Volume
            info           = 'Previous month %d last date.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = Volume
                storage_nr       = 39
            }
        }
        field {
            name           = prev_9_month
            quantity       = Volume
            info           = 'Previous month %d last date.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = Volume
                storage_nr       = 40
            }
        }
        field {
            name           = prev_10_month
            quantity       = Volume
            info           = 'Previous month %d last date.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = Volume
                storage_nr       = 41
            }
        }
        field {
            name           = prev_11_month
            quantity       = Volume
            info           = 'Previous month %d last date.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = Volume
                storage_nr       = 42
            }
        }
        field {
            name           = prev_12_month
            quantity       = Volume
            info           = 'Previous month %d last date.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = Volume
                storage_nr       = 43
            }
        }
        field {
            name           = prev_13_month
            quantity       = Volume
            info           = 'Previous month %d last date.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = Volume
                storage_nr       = 44
            }
        }
        field {
            name           = prev_14_month
            quantity       = Volume
            info           = 'Previous month %d last date.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = Volume
                storage_nr       = 45
            }
        }
        field {
            name           = total_energy_consumption
            quantity       = Energy
            info           = 'The total heat energy consumption recorded by this meter.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = AnyEnergyVIF
            }
        }
        field {
            name           = total_cooling_consumption
            quantity       = Energy
            info           = 'The total cooling energy consumption recorded by this meter.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = AnyEnergyVIF
                tariff_nr        = 1
            }
        }
        field {
            name           = total_volume
            quantity       = Volume
            info           = 'The total heating media volume recorded by this meter.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = Volume
            }
        }
        field {
            name       = status
            quantity   = Text
            info       = 'Status and error flags.'
            attributes = STATUS,INCLUDE_TPL_STATUS
            match {
                measurement_type = Instantaneous
                vif_range        = ErrorFlags
            }
            lookup {
                name            = ERROR_FLAGS
                map_type        = DecimalsToString
                mask_bits       = 0x270f
                default_message = OK
                map {
                    name  = VERIFICATION_EXPIRED
                    value = 2000
                    test  = Set
                }
                map {
                    name  = BATTERY_EXPIRED
                    value = 1000
                    test  = Set
                }
                map {
                    name  = WIRELESS_ERROR
                    value = 800
                    test  = Set
                }
                map {
                    name  = HARDWARE_ERROR3
                    value = 100
                    test  = Set
                }
                map {
                    name  = VALUE_OVERLOAD
                    value = 50
                    test  = Set
                }
                map {
                    name  = AIR_INSIDE
                    value = 40
                    test  = Set
                }
                map {
                    name  = REVERSE_FLOW
                    value = 30
                    test  = Set
                }
                map {
                    name  = DRY
                    value = 20
                    test  = Set
                }
                map {
                    name  = ERROR_MEASURING
                    value = 10
                    test  = Set
                }
                map {
                    name  = HARDWARE_ERROR2
                    value = 9
                    test  = Set
                }
                map {
                    name  = HARDWARE_ERROR1
                    value = 8
                    test  = Set
                }
                map {
                    name  = LOW_BATTERY
                    value = 7
                    test  = Set
                }
                map {
                    name  = SUPPLY_SENSOR_INTERRUPTED
                    value = 6
                    test  = Set
                }
                map {
                    name  = SHORT_CIRCUIT_SUPPLY_SENSOR
                    value = 5
                    test  = Set
                }
                map {
                    name  = RETURN_SENSOR_INTERRUPTED
                    value = 4
                    test  = Set
                }
                map {
                    name  = SHORT_CIRCUIT_RETURN_SENSOR
                    value = 3
                    test  = Set
                }
                map {
                    name  = TEMP_ABOVE_RANGE
                    value = 2
                    test  = Set
                }
                map {
                    name  = TEMP_BELOW_RANGE
                    value = 1
                    test  = Set
                }
            }
        }
        field {
            name           = due_energy_consumption
            quantity       = Energy
            info           = 'The total heat energy consumption at the due date.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = AnyEnergyVIF
                storage_nr       = 8
            }
        }
        field {
            name     = due_date
            quantity = Text
            info     = 'The due date.'
            match {
                measurement_type = Instantaneous
                vif_range        = Date
                storage_nr       = 8
            }
        }
        field {
            name           = volume_flow
            quantity       = Flow
            info           = 'The current heat media volume flow.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = VolumeFlow
            }
        }
        field {
            name           = power
            quantity       = Power
            info           = 'The current power consumption.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = PowerW
            }
        }
        field {
            name           = total_energy_consumption_last_month
            quantity       = Energy
            info           = 'The total heat energy consumption recorded at end of last month.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = AnyEnergyVIF
                storage_nr       = 32
            }
        }
        field {
            name         = last_month_date
            quantity     = Text
            info         = 'The due date.'
            display_unit = datetime
            match {
                measurement_type = Instantaneous
                vif_range        = DateTime
            }
        }
        field {
            name           = max_power_last_month
            quantity       = Power
            info           = 'Maximum power consumption last month.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Maximum
                vif_range        = PowerW
                storage_nr       = 32
                add_combinable   = PerMonth
            }
        }
        field {
            name           = flow_temperature
            quantity       = Temperature
            info           = 'The current forward heat media temperature.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = FlowTemperature
            }
        }
        field {
            name           = return_temperature
            quantity       = Temperature
            info           = 'The current return heat media temperature.'
            vif_scaling    = Auto
            dif_signedness = Signed
            match {
                measurement_type = Instantaneous
                vif_range        = ReturnTemperature
            }
        }
    }
    tests {
        test {
            args     = 'Heat c5isf 55445555 NOKEY'
            telegram = E544496A55554455880D7A320200002F2F_
            json     = '{"_":"telegram","media":"heat/cooling load","meter":"c5isf","name":"Heat","id":"55445555","total_energy_consumption_kwh":0,"total_volume_m3":0,"status":"ERROR REVERSE_FLOW SUPPLY_SENSOR_INTERRUPTED","prev_1_month":"2017-04-01","prev_2_month":"2127-15-31","prev_3_month":"2127-15-31","prev_4_month":"2127-15-31","prev_5_month":"2127-15-31","prev_6_month":"2127-15-31","prev_7_month":"2127-15-31","prev_8_month":"2127-15-31","prev_9_month":"2127-15-31","prev_10_month":"2127-15-31","prev_11_month":"2127-15-31","prev_12_month":"2127-15-31","prev_13_month":"2127-15-31","prev_14_month":"2127-15-31","prev_1_month_kwh":0,"prev_2_month_kwh":-2147483648,"prev_3_month_kwh":-2147483648,"prev_4_month_kwh":-2147483648,"prev_5_month_kwh":-2147483648,"prev_6_month_kwh":-2147483648,"prev_7_month_kwh":-2147483648,"prev_8_month_kwh":-2147483648,"prev_9_month_kwh":-2147483648,"prev_10_month_kwh":-2147483648,"prev_11_month_kwh":-2147483648,"prev_12_month_kwh":-2147483648,"prev_13_month_kwh":-2147483648,"prev_14_month_kwh":-2147483648,"total_energy_consumption_last_month_kwh":0,"timestamp":"1111-11-11T11:11:11Z"}'
            fields   = 'Heat;55445555;0;0;ERROR REVERSE_FLOW SUPPLY_SENSOR_INTERRUPTED;1111-11-11 11:11.11'
        }
        test {
            args     = 'Heat c5isf 32002044 NOKEY'
            comment  = 'Test telegram with max_power_last_month_kwh which is non-zero'
            telegram = 5E44496A4420003288047AFC0050052F2F_0406D00E00000413B28A05008404060000000082046CC121043B00000000042D000000000259E719025D051402FD17000084800106C00C00008280016CC125948001AE25090000002F2F2F2F2F2F
            json     = '{"_":"telegram","media":"heat","meter":"c5isf","name":"Heat","id":"32002044","total_energy_consumption_kwh":3792,"total_volume_m3":363.186,"status":"OK","prev_1_month":"2022-05-01","prev_1_month_kwh":3264,"due_energy_consumption_kwh":0,"due_date":"2022-01-01","volume_flow_m3h":0,"power_kw":0,"total_energy_consumption_last_month_kwh":3264,"max_power_last_month_kw":9,"flow_temperature_c":66.31,"return_temperature_c":51.25,"timestamp":"1111-11-11T11:11:11Z"}'
            fields   = 'Heat;32002044;3792;363.186;OK;1111-11-11 11:11.11'
        }
        test {
            args     = 'HeatCool c5isf 32022703 NOKEY'
            telegram = 8E44496A03270232880D7AED0080052F2F0406050200008410069A1700000413BC6F2E00840406E701000082046C2131841406C20B000082146C2131043B00000000042D0000000002595D09025D240802FD17000084800106050200008280016C213C948001AE2501000000849001069A1700008290016C213C849001AE25000000002F2F2F2F2F2F2F2F2F2F2F2F
            json     = '{"_": "telegram","due_date": "2025-01-01","due_energy_consumption_kwh": 487,"flow_temperature_c": 23.97,"id": "32022703","max_power_last_month_kw": 1,"media": "heat/cooling load","meter": "c5isf","name": "HeatCool","power_kw": 0,"prev_1_month": "2025-12-01","prev_1_month_kwh": 517,"return_temperature_c": 20.84,"status": "OK","timestamp": "1111-11-11T11:11:11Z","total_cooling_consumption_kwh": 6042,"total_energy_consumption_kwh": 517,"total_energy_consumption_last_month_kwh": 517,"total_volume_m3": 3043.26,"volume_flow_m3h": 0}'
            fields   = 'HeatCool;32022703;517;3043.26;OK;1111-11-11 11:11.11'
        }
    }
}
